  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:vercel": "cross-env NITRO_PRESET=vercel vite build",
    "build:cloudflare": "cross-env NITRO_PRESET=cloudflare vite build --mode cloudflare && node -e \"const fs=require('fs'); const path=require('path'); const serverDir='dist/server'; const serverAssets=path.join(serverDir, 'assets'); let workerPath; if(fs.existsSync(serverAssets)){ const workerFile=fs.readdirSync(serverAssets).find(f=>f.startsWith('worker-entry-') && f.endsWith('.js')); if(workerFile) workerPath=path.join(serverAssets, workerFile); } if(!workerPath && fs.existsSync(path.join(serverDir, 'server.js'))) workerPath=path.join(serverDir, 'server.js'); if(workerPath){ fs.copyFileSync(workerPath, 'dist/client/_worker.js'); console.log('Successfully created dist/client/_worker.js from ' + workerPath); } else { console.error('Could not find server entry point'); process.exit(1); }\"",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:api": "bun tests/run-api-ai-tests.ts",
    "test:api:only": "bun test tests/api-ai-validation.test.ts"
  },
